{
	"name": "blog",
	"version": "1.3.2",
	"description": "The ReverentGeek Blog using Eleventy",
	"scripts": {
		"clean": "node scripts/clean.js",
		"clean:all": "rimraf dist",
		"serve:css": "postcss src/assets/css/styles.css --output dist/assets/index.css --watch",
		"serve:js": "esbuild src/assets/js/index.js src/assets/js/prism.js --bundle --outdir=dist/assets --watch",
		"serve:eleventy": "ELEVENTY_ENV=development eleventy --serve",
		"serve": "npm-run-all2 clean --parallel serve:*",
		"build:css": "postcss src/assets/css/styles.css --output dist/assets/index.css --no-map",
		"build:js": "esbuild src/assets/js/index.js src/assets/js/prism.js --bundle --outdir=dist/assets --minify",
		"build:eleventy": "ELEVENTY_ENV=production eleventy",
		"build:prune": "node scripts/prune-images.js",
		"build": "NODE_ENV=production run-s clean build:css build:js build:eleventy build:prune",
		"start": "pnpm run serve",
		"lint": "eslint . --ext .cjs --ext .js --cache",
		"lint:markdown": "markdownlint src/**/*.md",
		"post": "node src/utils/post.js",
		"test": "pnpm run test:smoke",
		"test:smoke": "pnpm run build && node --test test/smoke.test.js",
		"test:lighthouse": "lighthouse --view https://reverentgeek.com --output html --output-path ./reports/report.html"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/reverentgeek/blog.git"
	},
	"engines": {
		"node": ">=24"
	},
	"keywords": [
		"eleventy",
		"static",
		"site",
		"jamstack",
		"reverentgeek",
		"blog"
	],
	"author": "David Neal",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/reverentgeek/blog/issues"
	},
	"homepage": "https://github.com/reverentgeek/blog#readme",
	"type": "module",
	"dependencies": {
		"@11ty/eleventy": "4.0.0-alpha.7",
		"@11ty/eleventy-img": "^6.0.4",
		"@11ty/eleventy-plugin-rss": "^3.0.0",
		"@tailwindcss/postcss": "^4.3.0",
		"eleventy-plugin-broken-links": "^2.2.1",
		"eleventy-plugin-edgejs": "^1.1.9",
		"esbuild": "^0.28.0",
		"html-minifier-terser": "^7.2.0",
		"npm-run-all2": "^8.0.4",
		"postcss": "^8.5.14",
		"postcss-cli": "^11.0.1",
		"postcss-import": "^16.1.1",
		"prismjs": "^1.30.0",
		"rimraf": "^6.1.3",
		"tailwindcss": "^4.3.0"
	},
	"devDependencies": {
		"commander": "^14.0.3",
		"eslint": "^10.4.0",
		"eslint-config-reverentgeek": "^7.1.7",
		"fs-extra": "^11.3.5",
		"jimp": "^1.6.1",
		"lighthouse": "^13.3.0",
		"markdownlint-cli": "^0.48.0",
		"netlify-plugin-cache": "^1.0.3",
		"probe-image-size": "^7.3.0",
		"slug": "^11.0.1",
		"uuid": "^14.0.0"
	},
	"packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499",
	"pnpm": {
		"onlyBuiltDependencies": [
			"@tailwindcss/oxide",
			"esbuild"
		],
		"overrides": {
			"file-type@>=13.0.0 <21.3.1": ">=21.3.1",
			"brace-expansion@<1.1.13": ">=1.1.13",
			"brace-expansion@>=2.0.0 <2.0.3": ">=2.0.3"
		}
	}
}
